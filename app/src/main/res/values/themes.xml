<resources>
    <!-- Base application theme using Material 3 -->
    <style name="Theme.Futoshiki" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your theme here if needed -->
    </style>

    <style name="Theme.Futoshiki.Fire" parent="Theme.Futoshiki">
        <item name="colorPrimary">#FFFF404E</item>
    </style>

    <style name="Theme.Futoshiki.Water" parent="Theme.Futoshiki">
        <item name="colorPrimary">#0088FF</item>
    </style>

    <style name="Theme.Futoshiki.Earth" parent="Theme.Futoshiki">
        <item name="colorPrimary">#34C759</item>
    </style>

    <style name="Theme.Futoshiki.Wood" parent="Theme.Futoshiki">
        <item name="colorPrimary">#FF8D28</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#f4f3f1</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Futoshiki</item>
    </style>
</resources>
